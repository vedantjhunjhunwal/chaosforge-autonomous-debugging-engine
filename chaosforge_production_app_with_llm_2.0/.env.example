CHAOSFORGE_SECRET_KEY=change-me-in-production
DATABASE_URL=sqlite:///./chaosforge.db
ARTIFACT_ROOT=artifacts
CHAOSFORGE_WORKERS=2

# LLM settings
# off  = never call LLM
# auto = use LLM if key exists, otherwise fallback to deterministic agents
# strict = fail if LLM call fails
LLM_MODE=auto
LLM_PROVIDER=off
LLM_MODEL=gpt-4o-mini
LLM_REQUEST_TIMEOUT=45

# OpenAI / OpenAI-compatible
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Gemini
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
